{
  "ignoreDependencies": [
    ".prisma",
    "@dnd-kit/helpers",
    "@emotion/styled",
    "archiver"
  ],
  "ignoreExports": [
    {
      "file": "src/app/**/*.{ts,tsx}",
      "exports": ["Route"]
    }
  ],
  "duplicates": {
    "minOccurrences": 3,
    "ignore": [
      "src/routeTree.gen.ts",
      "src/components/api/hooks/useAdd*.ts",
      "src/components/api/hooks/useUpdate*.ts",
      "src/components/api/hooks/useReorder*.ts",
      "src/app/api/organizations.*.receipts.*.ts",
      "src/app/api/organizations.*.taxRecords.*.ts"
    ]
  },
  "health": {
    "maxCyclomatic": 20,
    "maxCognitive": 35,
    "maxCrap": 500,
    "ignore": [
      "src/routeTree.gen.ts"
    ]
  }
}